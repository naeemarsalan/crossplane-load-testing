# Primary cluster (self-managed OpenShift)
CLUSTER_API_URL=https://api.crossplane1.sandbox845.opentlc.com:6443
CLUSTER_USERNAME=kubeadmin
CLUSTER_PASSWORD=<from install>

# Grafana
GRAFANA_URL=http://your-grafana:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_your_token_here

# External Prometheus
PROM_URL=https://your-prometheus.example.com
PROM_REMOTE_WRITE_URL=https://prom/api/v1/write
PROM_QUERY_URL=https://prom

